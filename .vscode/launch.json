{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "pwa-node",
      "request": "launch",
      "name": "Launch with ABS",
      "skipFiles": ["<node_internals>/**"],
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "env": {
        "VITE_ACCOUNTS_HOST_URL":"https://accounts.cbddev.xyz",
        "VITE_API_URL":"https://api.cbddev.xyz",
        "BASE_PATH":"/clearing-house/"
      },
      "console": "integratedTerminal"
    },
    {
      "type": "node-terminal",
      "request": "launch",
      "name": "Build & Preview (/clearing-house/)",
      "command": "BASE_PATH=/clearing-house/ npm run build && npx vitepress preview docs --port 4173",
      "env": {
        "VITE_ACCOUNTS_HOST_URL":"https://accounts.cbddev.xyz",
        "VITE_API_URL":"https://api.cbddev.xyz",
        "BASE_PATH":"/clearing-house/"
      }
    }
  ]
}
