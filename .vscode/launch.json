  "version": "0.2.0",
  "configurations": [
    {
      "type": "pwa-node",
      "request": "launch",
      "name": "Launch with ABS",
      "skipFiles": ["<node_internals>/**"],
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "env": {
        "VITE_CLEARING_HOUSE": "abs",
        "VITE_ACCOUNTS_HOST_URL":"https://accounts.cbddev.xyz",
        "VITE_API_URL":"https://api.cbddev.xyz"
      },
      "console": "integratedTerminal"
    },
    {
